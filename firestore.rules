rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Teachers document validation
    function isValidTeacher(data) {
      return data.userId is string 
          && data.userId.size() <= 128
          && data.teacherName is string 
          && data.teacherName.size() <= 100
          && (data.subject == null || (data.subject is string && data.subject.size() <= 100))
          && (data.currency == null || (data.currency is string && data.currency.size() <= 20))
          && (data.passcode == null || (data.passcode is string && data.passcode.size() <= 32))
          && (data.primaryColor == null || (data.primaryColor is string && data.primaryColor.size() <= 30))
          && (data.enableWhatsApp24hReminders == null || data.enableWhatsApp24hReminders is bool)
          && (data.autoBackupDownloadInterval == null || data.autoBackupDownloadInterval is string)
          && (data.students == null || data.students is list)
          && (data.appointments == null || data.appointments is list)
          && (data.examAppointments == null || data.examAppointments is list)
          && (data.updatedAt != null);
    }

    // 2. Teachers Collection Security block
    match /teachers/{userId} {
      // Must be owner to do any read or write
      allow get, list: if isOwner(userId);
      
      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && isValidTeacher(incoming())
                    && incoming().userId == request.auth.uid;
                    
      allow update: if isOwner(userId)
                    && isValidTeacher(incoming())
                    && incoming().userId == request.auth.uid
                    && incoming().userId == existing().userId; // Immutable Owner Field
                    
      allow delete: if isOwner(userId);
    }
  }
}
